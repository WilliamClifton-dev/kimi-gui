{
  "name": "kimi-gui",
  "version": "0.2.0",
  "private": true,
  "description": "面向中文新手的 Kimi Code 本地桌面工作台。",
  "main": "dist-electron/src-main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build:web": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:web && npm run build:main",
    "audit:publish": "npm run build:main && node dist-electron/src-main/tools/publish-audit.js",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.main.json",
    "dist:win": "npm run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "@moonshot-ai/kimi-agent-sdk": "^0.1.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "dev.williamclifton.kimigui",
    "productName": "Kimi GUI",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kimi GUI",
      "artifactName": "Kimi-GUI-Setup-${version}-${arch}.${ext}"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "Kimi-GUI-Portable-${version}-${arch}.${ext}"
    }
  },
  "author": "WilliamClifton-dev"
}
